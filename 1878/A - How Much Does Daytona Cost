#include<iostream>
using namespace std;
int main(){
    int n;
    cin>>n;
    for(int i=0;i<n;i++){
        long long size;
        cin>>size;
        long long k;
        cin>>k;
        long long arr[size];
        for(int j=0;j<size;j++){
            cin>>arr[j];
        }
        bool found = false;
        for(int l=0;l<size;l++){
            if(arr[l]==k){
                found = true;
            }
        }
        if(found){
            cout<<"YES"<<endl;
        } else {
            cout<<"NO"<<endl;
        }
    }
}